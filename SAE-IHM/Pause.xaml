<Window x:Class="SAE_IHM.Pause"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PAUSE" Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">

    <Grid Background="#FFECF0F1" Margin="20">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">

            <TextBlock Text="PAUSE" FontSize="32" FontWeight="Bold" Foreground="#FF2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <Button x:Name="BtnReprendre" Content="Reprendre la partie" Height="45" Margin="0,10,0,10" FontSize="16" FontWeight="SemiBold" Background="#FF2ECC71" Foreground="White" Cursor="Hand" Click="BtnReprendre_Click"/>

            <Button x:Name="BtnMenu" Content="Revenir au menu principal" Height="45" Margin="0,10,0,10" FontSize="16" FontWeight="SemiBold" Background="#FF3498DB" Foreground="White" Cursor="Hand" Click="BtnMenu_Click"/>

            <Button x:Name="BtnQuitter" Content="Quitter le jeu" Height="45" Margin="0,10,0,10" FontSize="16" FontWeight="SemiBold" Background="#FFE74C3C" Foreground="White" Cursor="Hand" Click="BtnQuitter_Click"/>

        </StackPanel>
    </Grid>
</Window>