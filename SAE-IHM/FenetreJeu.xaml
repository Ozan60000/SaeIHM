<Window x:Class="SAE_IHM.FenetreJeu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puissance 4" Height="700" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        Loaded="Window_Loaded"
        KeyDown="Window_KeyDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="LblTitre" Text="Partie" FontSize="18" FontWeight="Bold" Foreground="#2C3E50" Margin="0,0,0,10" HorizontalAlignment="Left" VerticalAlignment="Center"/>
        <TextBlock Grid.Row="0" x:Name="LblTourJoueur" Text="C'est au tour de..." HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" Margin="0,0,0,10"/>

        <Button Grid.Row="0" x:Name="BtnPause" Content="Pause" Width="80" Height="35" Margin="0,0,0,10" HorizontalAlignment="Right" VerticalAlignment="Center" Click="BtnPause_Click" Background="#FF95A5A6" Foreground="White" FontWeight="Bold" Cursor="Hand"/>

        <Border Grid.Row="1" Background="#3498DB" CornerRadius="10" Padding="10">
            <UniformGrid x:Name="GrillePlateau"/>
        </Border>

        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="LblJoueur1" Text="Joueur 1" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <ContentControl x:Name="IndicateurJ1" Width="22" Height="22" Margin="10,0,0,0"/>
                </StackPanel>
                <TextBlock x:Name="LblChronoJ1" Text="Chronomètre : --:--" FontSize="12" Margin="0,5,0,0" Foreground="#7F8C8D"/>
                <TextBlock x:Name="LblReflexionJ1" Text="Temps de réflexion : --:--" FontSize="12" Foreground="#7F8C8D"/>
            </StackPanel>

            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ContentControl x:Name="IndicateurJ2" Width="22" Height="22" Margin="0,0,10,0"/>
                    <TextBlock x:Name="LblJoueur2" Text="Joueur 2" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="LblChronoJ2" Text="Chronomètre : --:--" FontSize="12" Margin="0,5,0,0" HorizontalAlignment="Right" Foreground="#7F8C8D"/>
                <TextBlock x:Name="LblReflexionJ2" Text="Temps de réflexion : --:--" FontSize="12" HorizontalAlignment="Right" Foreground="#7F8C8D"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>