<Window x:Class="SAE_IHM.FenetreJeu"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puissance 4" Height="700" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#ECF0F1"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Titre de la partie -->
        <TextBlock Grid.Row="0" x:Name="LblTitre" Text="Partie"
                   FontSize="18" FontWeight="Bold" 
                   Foreground="#2C3E50" Margin="0,0,0,15"/>

        <!-- Plateau de jeu (rempli dynamiquement) -->
        <Border Grid.Row="1" Background="#3498DB" CornerRadius="10" Padding="10">
            <UniformGrid x:Name="GrillePlateau"/>
        </Border>

        <!-- Bas : Joueurs et boutons de navigation -->
        <Grid Grid.Row="2" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Joueur 1 -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Left">
                <TextBlock x:Name="LblJoueur1" Text="Joueur 1" 
                           FontSize="16" FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <Ellipse Width="22" Height="22" Fill="Red" 
                         Stroke="Black" StrokeThickness="1"
                         Margin="10,0,0,0"/>
            </StackPanel>

            <!-- Boutons navigation des coups (mode replay - à implémenter plus tard) -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Button x:Name="BtnPrecedent" Content="◄" 
                        Width="45" Height="45" Margin="5,0" 
                        IsEnabled="False"/>
                <Button x:Name="BtnSuivant" Content="►" 
                        Width="45" Height="45" Margin="5,0" 
                        IsEnabled="False"/>
            </StackPanel>

            <!-- Joueur 2 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Ellipse Width="22" Height="22" Fill="Gold" 
                         Stroke="Black" StrokeThickness="1"
                         Margin="0,0,10,0"/>
                <TextBlock x:Name="LblJoueur2" Text="Joueur 2" 
                           FontSize="16" FontWeight="Bold" 
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>