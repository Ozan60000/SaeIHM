<Window x:Class="SAE_IHM.FinPartie"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Partie terminée" Width="600" SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        WindowStyle="ToolWindow">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFECF0F1" Margin="20">
        <Border Background="White" BorderBrush="#FFBDC3C7" BorderThickness="2" CornerRadius="10" Padding="20">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="450">

                <TextBlock x:Name="LblTitreFin" Text="Victoire du joueur 1"
                           FontSize="32" FontWeight="Bold" Foreground="#FF2C3E50"
                           HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,10"/>

                <TextBlock x:Name="LblScore" Text="Score total des parties : (J1) 1 - 0 (J2)"
                           FontSize="16" Foreground="#FF7F8C8D"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnRelancer" Content="Relancer une partie contre le même adversaire" 
                        Background="#FF2ECC71" Foreground="White" 
                        IsDefault="True" Click="BtnRelancer_Click"/>

                <Button x:Name="BtnMenu" Content="Revenir au menu principal" 
                        Background="#FF3498DB" Foreground="White" 
                        Click="BtnMenu_Click"/>

                <Button x:Name="BtnQuitter" Content="Quitter le jeu" 
                        Background="#FFE74C3C" Foreground="White" 
                        Click="BtnQuitter_Click"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>