<Window x:Class="SAE_IHM.ChoixCouleur"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Couleur des jetons" Height="500" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFECF0F1" Margin="20">
        <StackPanel>

            <TextBlock Text="Couleur des jetons"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#FF2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="Sélection pour : " FontSize="14" VerticalAlignment="Center"/>
                <RadioButton x:Name="RadJ1" Content="Joueur 1" IsChecked="True" Margin="10,0,15,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="RadJ2" Content="Joueur 2" VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Rows="2" Columns="3" Height="220">
                <Button Tag="Aléatoire" Content="Aléatoire"
                        Background="LightGray" Foreground="Black"
                        Margin="5" FontWeight="SemiBold" FontSize="14"
                        Click="BtnCouleur_Click"/>
                <Button Tag="Rouge" Content="Rouge"
                        Background="Red" Foreground="White"
                        Margin="5" FontWeight="Bold" FontSize="14"
                        Click="BtnCouleur_Click"/>
                <Button Tag="Jaune" Content="Jaune"
                        Background="Gold" Foreground="Black"
                        Margin="5" FontWeight="Bold" FontSize="14"
                        Click="BtnCouleur_Click"/>
                <Button Tag="Bleu" Content="Bleu"
                        Background="DodgerBlue" Foreground="White"
                        Margin="5" FontWeight="Bold" FontSize="14"
                        Click="BtnCouleur_Click"/>
                <Button Tag="Violet" Content="Violet"
                        Background="MediumPurple" Foreground="White"
                        Margin="5" FontWeight="Bold" FontSize="14"
                        Click="BtnCouleur_Click"/>
                <Button Tag="Vert" Content="Vert"
                        Background="ForestGreen" Foreground="White"
                        Margin="5" FontWeight="Bold" FontSize="14"
                        Click="BtnCouleur_Click"/>
            </UniformGrid>

            <Border Background="White" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock x:Name="LblJ1" Text="Joueur 1 : Rouge" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock x:Name="LblJ2" Text="Joueur 2 : Jaune" FontSize="14"/>
                </StackPanel>
            </Border>

            <Button Content="Fermer" Width="120" Height="40"
                    Background="#FF95A5A6" Foreground="White"
                    FontWeight="SemiBold" Cursor="Hand"
                    HorizontalAlignment="Center" Margin="0,20,0,0"
                    Click="BtnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>