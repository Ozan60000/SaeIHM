<Window x:Class="SAE_IHM.ChoixForme"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Forme des jetons" Height="500" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFECF0F1" Margin="20">
        <StackPanel>
            <TextBlock Text="Forme des jetons" FontSize="22" FontWeight="Bold" Foreground="#FF2C3E50" HorizontalAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="Sélection pour : " FontSize="14" VerticalAlignment="Center"/>
                <RadioButton x:Name="RadJ1" Content="Joueur 1" IsChecked="True" Margin="10,0,15,0" VerticalAlignment="Center"/>
                <RadioButton x:Name="RadJ2" Content="Joueur 2" VerticalAlignment="Center"/>
            </StackPanel>

            <UniformGrid Rows="2" Columns="2" Height="150">
                <Button Tag="Cercle" Content="Cercle" Margin="5" FontSize="14" Click="BtnForme_Click"/>
                <Button Tag="Carré" Content="Carré" Margin="5" FontSize="14" Click="BtnForme_Click"/>
                <Button Tag="Losange" Content="Losange" Margin="5" FontSize="14" Click="BtnForme_Click"/>
                <Button Tag="Étoile" Content="Étoile" Margin="5" FontSize="14" Click="BtnForme_Click"/>
            </UniformGrid>

            <Border Background="White" CornerRadius="5" Padding="10" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock x:Name="LblJ1" Text="Joueur 1 : Cercle" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock x:Name="LblJ2" Text="Joueur 2 : Cercle" FontSize="14"/>
                </StackPanel>
            </Border>

            <Button Content="Fermer" Width="120" Height="40" Background="#FF95A5A6" Foreground="White" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Center" Margin="0,20,0,0" Click="BtnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>