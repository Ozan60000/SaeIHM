<Window x:Class="SAE_IHM.MenuJouer"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Puissance 4 - Menu Jouer" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Width" Value="280"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Background" Value="#FF3498DB"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFECF0F1">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="PUISSANCE 4"
                       FontSize="48"
                       FontWeight="Bold"
                       Foreground="#FF2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>

            <Button x:Name="BtnNouvellePartie" Content="Nouvelle partie" Click="BtnNouvellePartie_Click"/>
            <Button x:Name="BtnReprendre" Content="Reprendre une partie en pause" Click="BtnReprendre_Click"/>
            <Button x:Name="BtnHistorique" Content="Consulter l'historique" Click="BtnHistorique_Click"/>

            <Button x:Name="BtnRetour"
                    Content="Retour"
                    Background="#FF95A5A6"
                    Margin="0,30,0,0"
                    Click="BtnRetour_Click"/>

        </StackPanel>
    </Grid>
</Window>