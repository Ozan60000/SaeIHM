<Window x:Class="SAE_IHM.Historique"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Historique des parties" Height="450" Width="500"
        WindowStartupLocation="CenterScreen">

    <Grid Background="#FFECF0F1" Margin="20">
        <StackPanel>

            <TextBlock Text="Historique"
                       FontSize="28"
                       FontWeight="Bold"
                       Foreground="#FF2C3E50"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <ListBox x:Name="LstHistorique" Height="250" Margin="0,0,0,15"/>

            <TextBlock x:Name="LblMessage"
                       Text="Aucune partie enregistrée pour le moment."
                       Foreground="Gray"
                       FontStyle="Italic"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <Button x:Name="BtnFermer"
                    Content="Fermer"
                    Width="120"
                    Height="40"
                    Background="#FF95A5A6"
                    Foreground="White"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    Cursor="Hand"
                    Click="BtnFermer_Click"/>

        </StackPanel>
    </Grid>
</Window>