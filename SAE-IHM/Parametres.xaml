<Window x:Class="SAE_IHM.Parametres"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Paramètres" Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        FocusManager.FocusedElement="{Binding ElementName=SldContraste}">

    <Grid Background="#FFECF0F1" Margin="20">
        <StackPanel KeyboardNavigation.DirectionalNavigation="Cycle">

            <TextBlock Text="Paramètres" FontSize="32" FontWeight="Bold" Foreground="#FF2C3E50" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <TextBlock Text="Accessibilité de l'interface" FontSize="16" FontWeight="Bold" Foreground="#FF2C3E50" Margin="0,10,0,10"/>

            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Modifier le contraste" Grid.Column="0" VerticalAlignment="Center"/>
                <Slider x:Name="SldContraste" Grid.Column="1" Minimum="0" Maximum="100" Value="50" VerticalAlignment="Center"
                ValueChanged="SldContraste_ValueChanged"/>
            </Grid>

            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Modifier la taille du texte" Grid.Column="0" VerticalAlignment="Center"/>
                <Slider x:Name="SldTailleTexte" Grid.Column="1" Minimum="10" Maximum="36" Value="14" ValueChanged="SldTailleTexte_ValueChanged" VerticalAlignment="Center"/>
                <TextBlock x:Name="LblApercu" Text="A" Grid.Column="2" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Grid>

            <Separator Margin="0,20,0,10"/>

            <TextBlock Text="Personnaliser l'apparence" FontSize="16" FontWeight="Bold" Foreground="#FF2C3E50" Margin="0,10,0,10"/>

            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Changer les couleurs des jetons" Grid.Column="0" VerticalAlignment="Center"/>
                <Button x:Name="BtnCouleurs" Content="Ouvrir" Grid.Column="1" Width="100" Height="30" Background="#FF3498DB" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Click="BtnCouleurs_Click"/>
            </Grid>

            <Grid Margin="0,5,0,5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Changer la forme des jetons" Grid.Column="0" VerticalAlignment="Center"/>
                <Button x:Name="BtnFormes" Content="Ouvrir" Grid.Column="1" Width="100" Height="30" Background="#FF3498DB" Foreground="White" FontWeight="SemiBold" Cursor="Hand" Click="BtnFormes_Click"/>
            </Grid>

            <Button x:Name="BtnFermer" Content="Fermer" Width="120" Height="40" Background="#FF95A5A6" Foreground="White" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Center" Margin="0,30,0,0" IsCancel="True" Click="BtnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>